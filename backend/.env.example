c# ==============================================================================
# FilingPulse — Environment Variables Template
# ==============================================================================
# Copy this file to .env and fill in all values marked with <...>.
# The .env file is gitignored and must NEVER be committed.
#
# Quick start:
#   cp .env.example .env
#   # Edit .env with your real credentials
#   docker-compose up --build
# ==============================================================================

# ------------------------------------------------------------------------------
# App
# ------------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true

# Must be at least 32 characters. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<generate-a-random-32-char-hex-string>

# Comma-separated allowed origins for CORS.
# In production set this to your actual frontend domain, e.g.:
#   CORS_ORIGINS=https://app.filingpulse.com
CORS_ORIGINS=*

# ------------------------------------------------------------------------------
# Admin
# ------------------------------------------------------------------------------
# Bearer token required for POST /jurisdictions admin endpoint.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=<your-admin-api-key>

# ------------------------------------------------------------------------------
# Database (PostgreSQL + PostGIS)
# ------------------------------------------------------------------------------
# Database credentials (also used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=filingpulse

# When running via docker-compose, use the service name "db" as the host.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/filingpulse

# Connection pool tuning (optional)
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_TIMEOUT=30

# ------------------------------------------------------------------------------
# Third-party API Keys
# ------------------------------------------------------------------------------

# Socrata SODA App Token
# How to get one:
#   1. Create a free account at https://data.socrata.com (or any open-data portal)
#   2. Profile -> Developer Settings -> Create New App Token
#   3. Paste the token below.
# This is the global fallback; per-jurisdiction tokens can override it via
# POST /jurisdictions -> config.app_token.
SOCRATA_APP_TOKEN=<your-socrata-app-token>

# NOAA Climate Data Online (CDO) API Token
# Request a free token at: https://www.ncdc.noaa.gov/cdo-web/token
NOAA_TOKEN=<your-noaa-cdo-token>

# ------------------------------------------------------------------------------
# Email — choose backend: smtp | resend
# ------------------------------------------------------------------------------
EMAIL_BACKEND=smtp

# SMTP settings (used when EMAIL_BACKEND=smtp)
# For local dev with Mailhog: HOST=mailhog PORT=1025 USE_TLS=false
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USE_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=alerts@filingpulse.local
SMTP_FROM_NAME=FilingPulse Alerts

# Resend settings (used when EMAIL_BACKEND=resend)
# Sign up and create an API key at: https://resend.com/api-keys
RESEND_API_KEY=<your-resend-api-key>
RESEND_FROM_ADDRESS=alerts@filingpulse.com

# ------------------------------------------------------------------------------
# Scheduler
# ------------------------------------------------------------------------------
SCHEDULER_TIMEZONE=UTC
DEFAULT_POLL_INTERVAL_SECONDS=86400

# ------------------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------------------
FILINGS_RATE_LIMIT=60/minute
